---
# Atom feed for a single tag, generated by _plugins/tag_pages.rb.
# Field-set + whitespace handling mirror jekyll-feed's /feed.xml so
# per-tag feeds carry the same metadata, the full post content, and the
# same compact single-line structure (some feed readers fall back to
# Latin-1 when an XML file has lots of inter-element whitespace, even
# though the XML declaration says utf-8).
---
{%- assign tag_feed_url = '/tag/' | append: page.slug | append: '/feed.xml' | absolute_url -%}
{%- assign tag_html_url = '/tag/' | append: page.slug | append: '/' | absolute_url -%}
<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/"><generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator><link href="{{ tag_feed_url }}" rel="self" type="application/atom+xml"/><link href="{{ tag_html_url }}" rel="alternate" type="text/html"/>{%- if page.posts.first %}<updated>{{ page.posts.first.date | date_to_xmlschema }}</updated>{%- else %}<updated>{{ site.time | date_to_xmlschema }}</updated>{%- endif %}<id>{{ tag_feed_url }}</id><title type="html">{{ page.title | xml_escape }}</title><subtitle type="text">Posts tagged &quot;{{ page.tag | xml_escape }}&quot; on {{ site.title | xml_escape }}.</subtitle>{%- if site.author %}<author><name>{{ site.author.name | default: site.author | xml_escape }}</name>{%- if site.author.email %}<email>{{ site.author.email | xml_escape }}</email>{%- endif %}</author>{%- endif -%}
{%- for post in page.posts limit: 20 -%}
<entry><title type="html">{{ post.title | smartify | xml_escape }}</title><link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}"/><published>{{ post.date | date_to_xmlschema }}</published><updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated><id>{{ post.id | absolute_url }}</id><content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[{{ post.content | strip }}]]></content>{%- assign post_author_data = nil -%}{%- if post.author %}{%- assign post_author_data = site.authors[post.author] -%}{%- endif -%}{%- if post_author_data %}<author><name>{{ post_author_data.name | xml_escape }}</name>{%- if post_author_data.email %}<email>{{ post_author_data.email | xml_escape }}</email>{%- endif %}</author>{%- elsif site.author %}<author><name>{{ site.author.name | default: site.author | xml_escape }}</name>{%- if site.author.email %}<email>{{ site.author.email | xml_escape }}</email>{%- endif %}</author>{%- endif -%}{%- if post.description %}<summary type="html">{{ post.description | xml_escape }}</summary>{%- elsif post.excerpt %}<summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | truncate: 300 | xml_escape }}</summary>{%- endif -%}{%- if post.image %}<media:thumbnail xmlns:media="http://search.yahoo.com/mrss/" url="{{ post.image | absolute_url | xml_escape }}"/>{%- endif -%}{%- for c in post.categories %}<category term="{{ c | xml_escape }}"/>{%- endfor -%}{%- assign post_tags = post.tag | default: post.tags -%}{%- for t in post_tags %}<category term="{{ t | xml_escape }}"/>{%- endfor -%}</entry>
{%- endfor -%}
</feed>
