---
# Local override of jekyll-feed's default /feed.xml.
# Same Atom field-set the plugin generates, but every text-bearing field is
# piped through `ascii_only` so the file is pure 7-bit ASCII (non-ASCII
# codepoints become &#NNNN; numeric character references). This sidesteps
# brittle aggregators (e.g. jakartablogs.ee / Planet-style readers) that
# ignore <?xml encoding="utf-8"?> and fall back to Windows-1252 decoding,
# producing mojibake like "What€™s" for "What's". Atom <content type="html">
# readers HTML-decode the NCRs back into the correct characters at render
# time, so well-behaved clients see no difference.
#
# See _plugins/ascii_only.rb for the filter implementation.
layout: null
permalink: /feed.xml
sitemap: false
---
{%- assign feed_url    = '/feed.xml' | absolute_url -%}
{%- assign site_url    = '/'         | absolute_url -%}
<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/"><generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator><link href="{{ feed_url }}" rel="self" type="application/atom+xml"/><link href="{{ site_url }}" rel="alternate" type="text/html"/><updated>{{ site.time | date_to_xmlschema }}</updated><id>{{ feed_url }}</id><title type="html">{{ site.title | xml_escape | ascii_only }}</title>{%- if site.description %}<subtitle>{{ site.description | xml_escape | ascii_only }}</subtitle>{%- endif -%}{%- if site.author %}<author><name>{{ site.author.name | default: site.author | xml_escape | ascii_only }}</name>{%- if site.author.email %}<email>{{ site.author.email | xml_escape | ascii_only }}</email>{%- endif %}</author>{%- endif -%}
{%- assign posts = site.posts | where_exp: 'p', 'p.hidden != true' -%}
{%- for post in posts limit: 20 -%}
<entry><title type="html">{{ post.title | smartify | xml_escape | ascii_only }}</title><link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape | ascii_only }}"/><published>{{ post.date | date_to_xmlschema }}</published><updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated><id>{{ post.id | absolute_url }}</id><content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[{{ post.content | strip | ascii_only }}]]></content>{%- assign post_author_data = nil -%}{%- if post.author %}{%- assign post_author_data = site.authors[post.author] -%}{%- endif -%}{%- if post_author_data %}<author><name>{{ post_author_data.name | xml_escape | ascii_only }}</name>{%- if post_author_data.email %}<email>{{ post_author_data.email | xml_escape | ascii_only }}</email>{%- endif %}</author>{%- elsif site.author %}<author><name>{{ site.author.name | default: site.author | xml_escape | ascii_only }}</name>{%- if site.author.email %}<email>{{ site.author.email | xml_escape | ascii_only }}</email>{%- endif %}</author>{%- endif -%}{%- if post.description %}<summary type="html">{{ post.description | xml_escape | ascii_only }}</summary>{%- elsif post.excerpt %}<summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | truncate: 300 | xml_escape | ascii_only }}</summary>{%- endif -%}{%- if post.image %}<media:thumbnail xmlns:media="http://search.yahoo.com/mrss/" url="{{ post.image | absolute_url | xml_escape | ascii_only }}"/>{%- endif -%}{%- for c in post.categories %}<category term="{{ c | xml_escape | ascii_only }}"/>{%- endfor -%}{%- assign post_tags = post.tag | default: post.tags -%}{%- for t in post_tags %}<category term="{{ t | xml_escape | ascii_only }}"/>{%- endfor -%}</entry>
{%- endfor -%}
</feed>

